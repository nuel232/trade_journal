generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trade {
  id        Int      @id @default(autoincrement())
  date      String   // "YYYY-MM-DD"
  symbol    String
  type      String   // "BUY" | "SELL"
  lots      Float
  entry     Float
  exit      Float
  profit    Float
  session   String?  // "London" | "New York" | "Asian" — optional
  notes     String?  // trader's own notes
  createdAt DateTime @default(now())
}